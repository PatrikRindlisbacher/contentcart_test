<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="5.1" client="site" method="upgrade">
	<name>MOD_CONTENTCART_NAME</name>
	<namespace path="src">Joomline\Module\Contentcart</namespace>
    <author>Joomline</author>
    <authorEmail>sale@joomline.ru</authorEmail>
	<creationDate>@date@</creationDate>
    <authorurl>https://joomline.ru/</authorurl>
    <copyright>(C) 2018-2025 Joomline. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later</license>
    <version>@version@</version>
	<description>MOD_CONTENTCART_XML_DESCRIPTION</description>
	<files>
		<folder>services</folder>
		<folder module="mod_contentcart">src</folder>
		<folder>tmpl</folder>
		<folder>language</folder>
		<filename>joomla.asset.json</filename>
	</files>
	 <languages>
        <language tag="en-GB">language/en-GB/en-GB.mod_contentcart.ini</language>
        <language tag="en-GB">language/en-GB/en-GB.mod_contentcart.sys.ini</language>
        <language tag="ru-RU">language/ru-RU/ru-RU.mod_contentcart.ini</language>
        <language tag="ru-RU">language/ru-RU/ru-RU.mod_contentcart.sys.ini</language>
    </languages>

	<config>
		<fields name="params">
			<fieldset name="basic">
			<field
                    name="enable_css"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                    label="MOD_CONTENTCART_ENABLE_CSS"
                    description="MOD_CONTENTCART_ENABLE_CSS_DESC">
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
			</fieldset>
		</fields>
	</config>
</extension>
