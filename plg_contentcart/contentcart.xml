<?xml version="1.0" encoding="utf-8"?>
<extension version="5.1" type="plugin" group="content" element="contentcart" method="upgrade">
    <name>PLG_CONTENT_CONTENTCART</name>
    <namespace path="src">Joomline\Plugin\Content\Contentcart</namespace>
    <author>Joomline</author>
    <authorEmail>sale@joomline.ru</authorEmail>
    <creationDate>@date@</creationDate>
    <authorurl>https://joomline.ru/</authorurl>
    <copyright>(C) 2018-2025 Joomline. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later</license>
    <version>@version@</version>
    <description>PLG_CONTENTCART_DESC</description>
    <files>
        <folder>services</folder>
        <folder plugin="contentcart">src</folder>
        <folder>layouts</folder>
        <folder>tmpl</folder>
        <folder>language</folder>
        <filename>index.html</filename>
    </files>
    <media destination="plg_content_contentcart" folder="assets">
        <folder>css</folder>
        <folder>js</folder>
        <filename>joomla.asset.json</filename>
    </media>
    <languages folder="language">
        <language tag="en-GB">en-GB/en-GB.plg_content_contentcart.ini</language>
        <language tag="en-GB">en-GB/en-GB.plg_content_contentcart.sys.ini</language>
        <language tag="ru-RU">ru-RU/ru-RU.plg_content_contentcart.ini</language>
        <language tag="ru-RU">ru-RU/ru-RU.plg_content_contentcart.sys.ini</language>
        <language tag="de-DE">de-DE/de-DE.plg_content_contentcart.ini</language>
        <language tag="de-DE">de-DEde-DE.plg_content_contentcart.sys.ini</language>
    </languages>
    <config>
  <fields name="params" addfieldprefix="Joomla\Component\Content\Administrator\Field">
   <fieldset name="basic">

    <field name="mymenuitem" type="menuitem"
           default=""
           label="PLG_CONTENT_CONTENTCART_MENU"
           description="PLG_CONTENT_CONTENTCART_MENU_DESC">
     <option value="">JNO</option>
    </field>

    <field name="using_price"
           type="radio"
           label="PLG_CONTENT_CONTENTCART_PRICE_USING"
           description="PLG_CONTENT_CONTENTCART_PRICE_USING_DESC"
           class="btn-group btn-group-yesno"
           default="0">
     <option value="1">JYES</option>
     <option value="0">JNO</option>
    </field>

    <field name="price_id" type="text" label="PLG_CONTENT_CONTENTCART_PRICE_ID"
           description="PLG_CONTENT_CONTENTCART_PRICE_ID_DESC"/>
    <field name="currency" type="text" label="PLG_CONTENT_CONTENTCART_CURRENCY"
           description="PLG_CONTENT_CONTENTCART_CURRENCY_ID_DESC"/>

    <field name="category_filtering_type"
           type="radio"
           label="PLG_CONTENT_CONTENTCART_CATFILTERINGTYPE"
           description="PLG_CONTENT_CONTENTCART_CATFILTERINGTYPE_DESC"
           class="btn-group"
           default="1">
     <option value="1">PLG_CONTENT_CONTENTCART_CATEGORY_OPTION_INCLUSIVE</option>
     <option value="0">PLG_CONTENT_CONTENTCART_CATEGORY_OPTION_EXCLUSIVE</option>
    </field>

    <field name="catid"
           type="category"
           label="JCATEGORY"
           description="PLG_CONTENT_CONTENTCART_CATEGORY_DESC"
           extension="com_content"
           multiple="true"
           size="5"/>

    <field name="application_area"
           type="list"
           default="com_content.article"
           multiple="true"
           label="PLG_CONTENT_CONTENTCART_APPLICATION_AREA"
           description="PLG_CONTENT_CONTENTCART_APPLICATION_AREA_DESC">
     <option value="com_content.article">PLG_CONTENT_CONTENTCART_ARTICLE</option>
     <option value="com_content.category">PLG_CONTENT_CONTENTCART_BLOG</option>
     <option value="com_content.categories">PLG_CONTENT_CONTENTCART_CATEGORIES</option>
     <option value="com_content.featured">PLG_CONTENT_CONTENTCART_FEATURED</option>
    </field>

    <field name="cat_for_orders"
           type="category"
           label="PLG_CONTENT_CONTENTCART_CATEGORY_FOR_ORDERS"
           description="PLG_CONTENT_CONTENTCART_CATEGORY_FOR_ORDERS_DESC"
           extension="com_content"
           default="">
     <option value="">Не сохранять</option>
    </field>

    <field name="enable_css"
           type="radio"
           label="PLG_CONTENT_CONTENTCART_ENABLE_CSS"
           description="PLG_CONTENT_CONTENTCART_ENABLE_CSS_DESC"
           class="btn-group btn-group-yesno"
           default="1">
     <option value="1">JYES</option>
     <option value="0">JNO</option>
    </field>

    <field name="cart_ttl"
           type="number"
           label="PLG_CONTENT_CONTENTCART_CART_TTL"
           description="PLG_CONTENT_CONTENTCART_CART_TTL_DESC"
           default="30"
           min="1"
           max="365"
           step="1"/>

   </fieldset>

   <fieldset name="client_info" label="PLG_CONTENT_CONTENTCART_CLIENT_INFO_FIELDSET_LABEL">
   	<field name="client_name"
   	       type="list"
   	       label="PLG_CONTENT_CONTENTCART_CLIENT_NAME"
           description="PLG_CONTENT_CONTENTCART_CLIENT_NAME_DESC"
           default="0">
     <option value="2">PLG_CONTENT_CONTENTCART_REQUIRED</option>
     <option value="1">PLG_CONTENT_CONTENTCART_NOT_REQUIRED</option>
     <option value="0">PLG_CONTENT_CONTENTCART_NO</option>
    </field>

    <field name="client_email"
           type="list"
           label="PLG_CONTENT_CONTENTCART_CLIENT_EMAIL"
           description="PLG_CONTENT_CONTENTCART_CLIENT_EMAIL_DESC"
           default="0">
     <option value="2">PLG_CONTENT_CONTENTCART_REQUIRED</option>
     <option value="1">PLG_CONTENT_CONTENTCART_NOT_REQUIRED</option>
     <option value="0">PLG_CONTENT_CONTENTCART_NO</option>
    </field>

    <field name="client_phone"
           type="list"
           label="PLG_CONTENT_CONTENTCART_CLIENT_PHONE"
           description="PLG_CONTENT_CONTENTCART_CLIENT_PHONE_DESC"
           default="0">
     <option value="2">PLG_CONTENT_CONTENTCART_REQUIRED</option>
     <option value="1">PLG_CONTENT_CONTENTCART_NOT_REQUIRED</option>
     <option value="0">PLG_CONTENT_CONTENTCART_NO</option>
    </field>

    <field name="client_note"
           type="list"
           label="PLG_CONTENT_CONTENTCART_CLIENT_NOTE"
           description="PLG_CONTENT_CONTENTCART_CLIENT_NOTE_DESC"
           default="0">
     <option value="2">PLG_CONTENT_CONTENTCART_REQUIRED</option>
     <option value="1">PLG_CONTENT_CONTENTCART_NOT_REQUIRED</option>
     <option value="0">PLG_CONTENT_CONTENTCART_NO</option>
    </field>

    <field name="title_note" type="text"
           label="PLG_CONTENT_CONTENTCART_TITLE_NOTE"
           description="PLG_CONTENT_CONTENTCART_TITLE_NOTE_DESC"
           default=""/>

   </fieldset>
        </fields>
    </config>
</extension>
